# ---- Server ----
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ---- Database ----
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Create a free M0 cluster, add a database user, allow your IP, then copy the connection string.
MONGO_URI=mongodb://localhost:27017/oru-aka

# ---- Auth ----
# Any long random string. Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_this_with_a_different_long_random_string
JWT_REFRESH_EXPIRES_IN=30d

# ---- SMS OTP (Termii \u2014 Nigeria-focused SMS provider) ----
# Sign up at https://termii.com, get your API key from the dashboard.
# If left blank, the app runs in DEV OTP MODE: OTP codes are logged to the
# server console instead of being sent by SMS, so you can test without an account.
TERMII_API_KEY=
TERMII_SENDER_ID=OruAka

# ---- Image uploads (Cloudinary) ----
# Sign up at https://cloudinary.com (free tier). Find these on your dashboard home page.
# If left blank, uploads are skipped gracefully and a placeholder image is used.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Admin seed account (created by the seed script) ----
ADMIN_EMAIL=admin@oruaka.ng
ADMIN_PASSWORD=ChangeThisPassword123!
